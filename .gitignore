*.pyc
*.pyo
*.egg-info/
dist/
build/
.eggs/
*.egg
.venv/
venv/
env/

# ── IDE ──
.vscode/
.idea/
*.swp
*.swo
*~

# ── SUMO outputs (regenerable) ──
data/routes/*.rou.xml
